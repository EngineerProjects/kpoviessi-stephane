# ── LLM Provider Keys ──────────────────────────────────────────────────────
# Providers are tried in order: Groq → Gemini → ZhipuAI
# Any provider without a key is automatically skipped.
# At least one key must be set for the chatbot to work.

# Groq — free tier, fastest (console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# ZhipuAI GLM — fallback payant (open.bigmodel.cn)
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
